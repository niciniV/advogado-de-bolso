# Google AI Studio (https://aistudio.google.com/apikey)
# Pydantic AI (google) aceita GEMINI_API_KEY ou GOOGLE_API_KEY
GEMINI_API_KEY=

# Modelo Gemma 4 via Gemini API. Opcoes:
#   gemma-4-26b-a4b-it  (MoE, mais rapido)
#   gemma-4-31b-it      (denso, raciocinio mais forte)
LLM_MODEL=gemma-4-31b-it

# Provedor do modelo: google | openai | anthropic | etc.
LLM_PROVIDER=google

# Thinking level do Gemma 4: HIGH | MEDIUM | LOW | MINIMAL
# Vazio desabilita.
THINKING_LEVEL=HIGH

# Modelo de embedding local (HuggingFace). BGE-M3 e excelente para pt-BR.
EMBEDDING_MODEL=BAAI/bge-m3

# Caminhos
DATA_PATH=./data/raw
CHROMA_PATH=./storage/chroma
COLLECTION_NAME=advogado_de_bolso

# Retrieval
RETRIEVAL_TOP_K=5

# Cache local de modelos do HuggingFace
HF_HOME=./storage/hf_cache
