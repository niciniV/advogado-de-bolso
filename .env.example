# Copie este arquivo para .env e preencha os valores necessarios.
# Nunca versione o arquivo .env ou chaves reais.

# Chave da Gemini API criada no Google AI Studio:
# https://aistudio.google.com/apikey
# GEMINI_API_KEY tem prioridade quando as duas chaves estao preenchidas.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Identificador do modelo enviado ao provedor configurado em LLM_PROVIDER.
# Opcoes usadas pelo projeto com a Gemini API:
#   gemma-4-26b-a4b-it  (MoE, mais rapido)
#   gemma-4-31b-it      (denso, raciocinio mais forte)
LLM_MODEL=gemma-4-31b-it

# Provedor usado pelo Pydantic AI. A configuracao atual suporta google.
LLM_PROVIDER=google

# Nivel de raciocinio do modelo: HIGH, MEDIUM, LOW ou MINIMAL.
# Deixe vazio (THINKING_LEVEL=) para desabilitar.
THINKING_LEVEL=HIGH

# Modelo HuggingFace executado localmente para gerar embeddings dos documentos.
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Diretorio de entrada dos documentos que serao indexados.
DATA_PATH=./data/raw

# Diretorio onde o banco vetorial Chroma persiste o indice.
CHROMA_PATH=./storage/chroma

# Nome logico da colecao criada no Chroma.
COLLECTION_NAME=advogado_de_bolso

# Quantidade maxima de trechos recuperados para compor o contexto de cada resposta.
RETRIEVAL_TOP_K=5

# Diretorio de cache dos modelos baixados do HuggingFace.
HF_HOME=./storage/hf_cache
